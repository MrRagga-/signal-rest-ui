{
  "name": "signal-rest-ui",
  "version": "0.3.1",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrRagga-/signal-rest-ui.git"
  },
  "homepage": "https://github.com/MrRagga-/signal-rest-ui#readme",
  "bugs": {
    "url": "https://github.com/MrRagga-/signal-rest-ui/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "vite",
    "prepare:openapi": "node scripts/prepare-openapi.mjs",
    "generate:api": "pnpm prepare:openapi && orval --config orval.config.ts",
    "build:client": "vite build",
    "build:server": "tsup server/index.ts --format esm --platform node --out-dir dist-server --clean",
    "build": "pnpm generate:api && pnpm build:client && pnpm build:server",
    "preview": "node dist-server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.12",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "orval": "^8.6.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "swagger2openapi": "^7.0.8",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  }
}
