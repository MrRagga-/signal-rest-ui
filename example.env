# Copy this file to .env before running docker compose:
# cp example.env .env

SIGNAL_REST_UI_PORT=3000

APP_BRANDING_NAME=Signal Rest UI
APP_BRANDING_TAGLINE=Modern control surface for signal-cli-rest-api

DEFAULT_TRANSPORT=direct
DEFAULT_PROFILES_JSON=[]

PROXY_ENABLED=false
PROXY_BASE_PATH=/proxy
PROXY_ALLOWED_HOSTS=

REFRESH_INTERVAL_MS=15000
